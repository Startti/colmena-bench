{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colmena-bench/schemas/task.schema.json",
  "title": "Benchmark task definition",
  "description": "YAML/JSON task description loaded by the orchestrator and handed to every runner.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "version", "prompt", "metrics", "success"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{2}_[a-z0-9_]+$",
      "description": "Task slug, e.g. `01_hello_world`."
    },
    "title": { "type": "string", "minLength": 3 },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": { "type": "string" },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "enum": ["default", "S", "M", "L", "XL"] },
          "dataset_path": { "type": "string" },
          "params": { "type": "object", "additionalProperties": true }
        }
      },
      "minItems": 1
    },
    "prompt": {
      "type": "string",
      "minLength": 1,
      "description": "Verbatim prompt handed to the framework. Frameworks may wrap it; they must not modify the text."
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "spec_path": { "type": "string" }
        }
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "latency",
          "tokens",
          "tokens_cached",
          "cost_usd",
          "tool_calls",
          "ram_peak_mb",
          "cold_start_ms",
          "ttft_ms",
          "loc",
          "success"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "success": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["regex", "exact_numeric", "llm_judge", "set_equality"] },
        "pattern": { "type": "string" },
        "ground_truth_path": { "type": "string" },
        "tolerance": { "type": "number", "minimum": 0 },
        "judge_model": { "type": "string" }
      }
    },
    "model_alias": {
      "type": "string",
      "enum": ["gemini-2.5-flash", "claude-haiku", "gpt-4o-mini"],
      "default": "gemini-2.5-flash"
    },
    "timeout_seconds": { "type": "integer", "minimum": 1, "default": 300 },
    "n_runs": { "type": "integer", "minimum": 1, "default": 30 }
  }
}
