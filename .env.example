# colmena-bench — example environment variables.
# Copy this file to `.env` (which is gitignored) and fill in real values.
# NEVER commit a populated .env. CI gets these from repo secrets.

# --- LLM provider keys (required for any real run) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- LiteLLM proxy ---
# Where the proxy listens (used by runners as base_url override).
LITELLM_PROXY_HOST=127.0.0.1
LITELLM_PROXY_PORT=4000
LITELLM_PROXY_BASE_URL=http://127.0.0.1:4000

# Where the proxy writes one JSONL per run (T03).
LITELLM_SPANS_DIR=./proxy/spans

# Master key for the proxy. Validated WITHOUT a database; runners send it as
# their bearer (LITELLM_PROXY_API_KEY below must equal it). Generate with
# `openssl rand -hex 24` and prefix `sk-`. Do NOT enable virtual/allowed keys
# (they require Postgres → "No connected db." errors).
LITELLM_MASTER_KEY=
# Bearer the runners send to the proxy. Set equal to LITELLM_MASTER_KEY.
LITELLM_PROXY_API_KEY=

# --- Colmena base_url overrides (route Colmena's LLM calls through the proxy) ---
# Colmena's adapters honour these env vars (see the colmena base_url patch and
# docs/base_url_compatibility.md). For the bench we drive Colmena via its
# OpenAI adapter against the proxy's OpenAI-compatible /v1 route — the same
# proven path the Python runners use. Point OPENAI_BASE_URL at the proxy and
# run Colmena with provider=openai, model=gemini-2.5-flash.
OPENAI_BASE_URL=http://127.0.0.1:4000/v1
# Per-provider native-dialect routes (only if using LiteLLM pass-through):
# GEMINI_BASE_URL=http://127.0.0.1:4000/gemini/v1beta
# ANTHROPIC_BASE_URL=http://127.0.0.1:4000/anthropic
# Catch-all fallback if one host fronts all dialects:
# COLMENA_LLM_BASE_URL=

# --- Optional: state backend for HITL (T31) ---
# Defaults to file ./harness/state.db when unset.
# DATABASE_URL=sqlite:///./harness/state.db

# --- Benchmark run defaults ---
# NOTE: BENCH_RUN_ID is a PER-RUN value set by the orchestrator/caller, NOT a
# config default — never set it here (an empty value would clobber the proxy's
# per-run span routing). Pass it inline: `BENCH_RUN_ID=$(uuidgen) ...`.
BENCH_N=30
BENCH_TASK=01
BENCH_VARIANT=default
